# Supabase (browser — Vite exposes only VITE_* vars)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-only — Vercel Functions / local API routes)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin gate + server session (server-only; keep VITE_* copy for local client gate)
TMS_ADMIN_GATE_PASSWORD=your-admin-gate-password
TMS_ADMIN_SESSION_SECRET=generate-a-long-random-string
VITE_ADMIN_GATE_PASSWORD=your-admin-gate-password

# Phase 2+ only: manual journal/KPI mirror buttons (keep false in production until pilot)
VITE_SUPABASE_MANUAL_MIRROR_ENABLED=false

# Dev only: GET journal/ledger/KPI snapshots from production Blob (read-only). Off by default (quota).
# VITE_PROD_SNAPSHOT_PROXY=true

# Confluence 강의일지 (server-only — /api/confluence-lecture)
CONFLUENCE_BASE_URL=https://okestro.atlassian.net
CONFLUENCE_EMAIL=your-atlassian-email@example.com
CONFLUENCE_API_TOKEN=your-atlassian-api-token
CONFLUENCE_SPACE_KEY=rDzwjbV6p8qL
CONFLUENCE_LECTURE_FOLDER_ID=1867843025
CONFLUENCE_LECTURE_PARENT_TYPE=folder
